{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "strict": true,
        "jsx": "preserve",
        "importHelpers": true,
        "moduleResolution": "Node",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "types": ["vite/client"],
        "useDefineForClassFields": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "lib": ["ESNext", "DOM"],
        "paths": {
            "#build/ui/*": [
                "./node_modules/.nuxt-ui/ui/*"
            ]
        }
    },
    "include": [
        "resources/**/*.ts",
        "resources/**/*.d.ts",
        "resources/**/*.tsx",
        "resources/**/*.vue",
        "auto-imports.d.ts",
        "components.d.ts"
    ],
    "references": [{ "path": "./tsconfig.node.json" }],
    "exclude": ["node_modules"],
    "vueCompilerOptions": {
        "skipTemplateCodegen": true
    }
}
